# Keep this repository as a curated research artifact.
# The default rule ignores local scratch work; tracked files are added explicitly.
*

# Root metadata
!.gitignore
!.gitattributes
!README.md
!requirements.txt

# Curated repository content
!datasets/
!datasets/**
!notebooks/
!notebooks/**
!src/
!src/**
!models/
!models/**
!results/
!results/**

# Never track local/runtime artifacts
**/__pycache__/
**/.ipynb_checkpoints/
**/.venv/
**/.venv_*/
**/node_modules/
*.pyc
*.pyo
*.log
*.tmp
*.bak
Thumbs.db
.DS_Store

# Transfer bundles and local archives
*.zip
*.7z
*.rar
*.tar
*.tar.gz

# Training states that are not selected model artifacts
optimizer.pt
scheduler.pt
scaler.pt
rng_state.pth
pytorch_model.bin
*.ckpt
*.pt
*.pth

# The selected model weights under models/ are intentionally force-added.
